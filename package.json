{
  "name": "prompt-memory",
  "version": "0.0.0",
  "description": "Local-first prompt archive for AI coding tools.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlsdks/prompt-memory.git"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22 <25"
  },
  "bin": {
    "prompt-memory": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "docs/PRD.md",
    "docs/TECH_SPEC.md",
    "docs/IMPLEMENTATION_PLAN.md",
    "docs/ADAPTERS.md",
    "docs/RELEASE_CHECKLIST.md",
    "scripts/release-smoke.mjs"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build --config vite.web.config.ts",
    "clean": "rm -rf dist coverage",
    "format": "prettier --check package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\"",
    "format:write": "prettier --write package.json tsconfig.json tsconfig.web.json vite.web.config.ts vitest.config.ts \"scripts/**/*.mjs\" \"src/**/*.{ts,tsx,css}\" \".github/**/*.yml\"",
    "dev:web": "vite --config vite.web.config.ts",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm build",
    "prompt-memory": "node dist/cli/index.js",
    "smoke:release": "pnpm build && node scripts/release-smoke.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "fastify": "^5.8.5",
    "yaml": "^2.8.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "prettier": "^3.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vitest": "^3.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
